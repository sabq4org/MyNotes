# Server configuration
PORT=4000
NODE_ENV=development

# Database (PostgreSQL — e.g. Neon, Supabase, or local Postgres)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=

# Connection pool tuning
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

# Security
# Use a long random string in production. The server will auto-generate one
# at first run if this is empty, and persist it inside the database settings
# so tokens survive restarts.
JWT_SECRET=

# Authentication
# JWT lifetime in hours
JWT_EXPIRES_IN_HOURS=72

# Bcrypt cost factor for the master PIN/password hash
BCRYPT_COST=12

# CORS origin for the frontend during development
CORS_ORIGIN=http://localhost:5173
